# ============================================================
# llm-automation — sample.env (그라운드 룰 §6/§7)
# 사용법: cp sample.env .env  →  실제 값 채워 넣기
# 절대 .env 를 commit 하지 마세요. (.gitignore 차단)
# ============================================================

# ─── Phase 0 (_template 모듈) ───────────────────────────────
# 표준 검증용. 후속 Phase 진입 후 제거 가능.
TEMPLATE_GREETING_PREFIX=Hello

# ─── Phase 1 (libs/llm-gateway) ─────────────────────────────
# CLAUDE.md §5 의 generic alias 체계. 코드는 오직 이 키들만 참조한다.
# production ↔ test 매핑은 architecture_test.md §12 단일 출처.

# chat-llm (Workflow A — 코드 주석/생성)
CHAT_LLM_BASE_URL=https://api.openai.com/v1        # prod: http://pl99:19000/qwen
CHAT_LLM_MODEL=gpt-4o                              # prod: qwen3-coder-30b
CHAT_LLM_API_KEY=                                  # stack.yml 에서 OPENAI_API_KEY 매핑
CHAT_LLM_TIMEOUT_SECONDS=60                        # (선택) 기본 60
CHAT_LLM_MAX_RETRIES=3                             # (선택) 기본 3

# reasoning-llm (Workflow B — 분석/추론)
REASONING_LLM_BASE_URL=https://api.openai.com/v1   # prod: http://pl99:19000/gpt
REASONING_LLM_MODEL=o4-mini                        # prod: gpt-oss-130b
REASONING_LLM_API_KEY=                             # stack.yml 에서 OPENAI_API_KEY 매핑
REASONING_LLM_TIMEOUT_SECONDS=60
REASONING_LLM_MAX_RETRIES=3

# embedding (Qdrant collection 차원은 EMBEDDING_DIM 과 동기)
EMBEDDING_BASE_URL=https://api.openai.com/v1       # prod: http://pl99:19000/embed
EMBEDDING_MODEL=text-embedding-3-small             # prod: bge-m3
EMBEDDING_API_KEY=                                 # stack.yml 에서 OPENAI_API_KEY 매핑
EMBEDDING_DIM=1024                                 # prod bge-m3 동일 차원
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=3

# test 전용 source secret — stack.yml 의 *_API_KEY 에 매핑 (운영에서는 Swarm secret 사용)
OPENAI_API_KEY=

# ─── Phase 1 (libs/agent-runner) ─────────────────────────────
# Agent CLI 추상화. 어떤 Agent CLI 를 사용할지 + 타임아웃 설정.

# Agent CLI 종류: opencode | claude-code
AGENT_RUNNER_KIND=opencode

# subprocess wall-clock 제한 (초)
AGENT_TIMEOUT_SECONDS=300

# 작업 디렉터리 접두사
AGENT_WORK_DIR_PREFIX=/tmp/agent-runner

# ─── 후속 Phase 에서 추가될 키 (참고용) ─────────────────────
# Phase 2+ (services/*) 가 도착하면 여기에 추가됨.
