# ============================================================
# infra/ — sample.env (그라운드 룰 §6/§7)
# Docker Swarm stack 배포 시 사용하는 환경변수
# 사용법: cp sample.env .env  →  실제 값 채워 넣기
# ============================================================

# ─── LLM 추상화 (architecture_test.md §12.2 단일 출처) ──────

# chat-llm (Workflow A — 코드 주석/생성)
CHAT_LLM_BASE_URL=https://api.openai.com/v1
CHAT_LLM_MODEL=gpt-4o
CHAT_LLM_API_KEY=
CHAT_LLM_TIMEOUT_SECONDS=60
CHAT_LLM_MAX_RETRIES=3

# reasoning-llm (Workflow B — 분석/추론)
REASONING_LLM_BASE_URL=https://api.openai.com/v1
REASONING_LLM_MODEL=o4-mini
REASONING_LLM_API_KEY=
REASONING_LLM_TIMEOUT_SECONDS=60
REASONING_LLM_MAX_RETRIES=3

# embedding
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=3

# test 전용 source secret — stack 의 *_API_KEY 에 매핑
OPENAI_API_KEY=

# ─── Agent Runner ───────────────────────────────────────────
AGENT_RUNNER_KIND=opencode
AGENT_TIMEOUT_SECONDS=300
AGENT_WORK_DIR_PREFIX=/tmp/agent-runner

# ─── Celery ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
