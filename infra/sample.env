# ============================================================
# infra/ — sample.env (그라운드 룰 §6/§7)
# Docker Swarm stack 배포 시 사용하는 환경변수
# 사용법: cp sample.env .env  →  실제 값 채워 넣기
# ============================================================

# ─── LLM 추상화 (architecture_test.md §12.2 단일 출처) ──────

# chat-llm (Workflow A — 코드 주석/생성)
CHAT_LLM_BASE_URL=https://api.openai.com/v1
CHAT_LLM_MODEL=gpt-4o
CHAT_LLM_API_KEY=
CHAT_LLM_TIMEOUT_SECONDS=60
CHAT_LLM_MAX_RETRIES=3

# reasoning-llm (Workflow B — 분석/추론)
REASONING_LLM_BASE_URL=https://api.openai.com/v1
REASONING_LLM_MODEL=o4-mini
REASONING_LLM_API_KEY=
REASONING_LLM_TIMEOUT_SECONDS=60
REASONING_LLM_MAX_RETRIES=3

# embedding
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=3

# test 전용 source secret — stack 의 *_API_KEY 에 매핑
OPENAI_API_KEY=

# ─── Agent Runner ───────────────────────────────────────────
AGENT_RUNNER_KIND=opencode
AGENT_TIMEOUT_SECONDS=300
AGENT_WORK_DIR_PREFIX=/tmp/agent-runner

# ─── Celery ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── flask-webhook (Phase 5) ────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_SECRET=
DEDUP_TTL_SECONDS=300

# ─── celery-comment (Phase 5) ───────────────────────────────
COMMENT_WORK_DIR=/tmp/celery-comment
RAG_MCP_URL=http://rag-mcp:9001
GIT_COMMIT_AUTHOR=AI Bot <ai-bot@local>

# ─── celery-comment GitClient 선택 (Phase 6) ────────────────
# subprocess : 실제 git 명령 (운영 기본)
# fixture    : 파일 복사 기반 (E2E / 로컬 테스트)
GIT_CLIENT=subprocess
FIXTURE_SOURCE_DIR=/fixtures/source
FIXTURE_RESULT_DIR=/fixtures/results

# ─── celery-configaudit (Phase 5) ───────────────────────────
CONFIGAUDIT_MCP_URL=http://configaudit-mcp:9002
REPORT_OUTPUT_DIR=/reports

# ─── E2E Harness (Phase 6) ──────────────────────────────────
# E2E_ENABLED=1 설정 시에만 e2e 시나리오 실행 (OpenAI 호출)
E2E_ENABLED=
E2E_STACK_NAME=llmauto-e2e
E2E_BROKER_URL=redis://localhost:6379/0
E2E_STACK_STARTUP_TIMEOUT=120
E2E_TASK_TIMEOUT=180
E2E_FIXTURES_DIR=e2e/fixtures
