{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConfigAudit AnalysisReport (E2E scenario B)",
  "type": "object",
  "required": [
    "work_id",
    "case",
    "summary",
    "anomalies",
    "details",
    "generated_at"
  ],
  "properties": {
    "work_id": { "type": "string", "minLength": 1 },
    "case": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "anomalies": {
      "type": "array",
      "items": { "type": "object" }
    },
    "details": {
      "type": "object"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
