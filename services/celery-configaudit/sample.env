# celery-configaudit 환경변수
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CONFIGAUDIT_MCP_URL=http://localhost:9002
REASONING_LLM_BASE_URL=https://api.openai.com/v1
REASONING_LLM_MODEL=o4-mini
REASONING_LLM_API_KEY=
REASONING_LLM_TIMEOUT_SECONDS=60
REPORT_OUTPUT_DIR=/tmp/celery-configaudit/reports
AGENT_MAX_ITERATIONS=5
