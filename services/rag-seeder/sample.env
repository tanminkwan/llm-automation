# rag-seeder 설정 (설계서 §6 참조)

# corpus
SEEDER_CORPUS_DIR=corpus                   # 코퍼스 YAML 디렉터리
SEEDER_COLLECTION_NAME=code_comments       # Qdrant 컬렉션명
SEEDER_BATCH_SIZE=32                       # 배치당 snippet 수
SEEDER_REPO_NAME=seed-repo                 # payload repo 필드

# qdrant
QDRANT_URL=http://localhost:6333
QDRANT_TIMEOUT=30.0

# embedding 차원 (llm-gateway 와 공유)
EMBEDDING_DIM=1024
