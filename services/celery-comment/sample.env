# celery-comment 환경변수
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
COMMENT_WORK_DIR=/tmp/celery-comment
RAG_MCP_URL=http://localhost:9001
AGENT_RUNNER_KIND=opencode
AGENT_TIMEOUT_SECONDS=300
GIT_COMMIT_AUTHOR=AI Bot <ai-bot@local>

# --- GitClient 구현체 선택 (Phase 6) ---
# subprocess  : 운영 기본 (실제 git 명령 실행)
# fixture     : E2E / 로컬 테스트 (파일 복사 기반, 아래 경로 필수)
GIT_CLIENT=subprocess
FIXTURE_SOURCE_DIR=/fixtures/source
FIXTURE_RESULT_DIR=/fixtures/results
